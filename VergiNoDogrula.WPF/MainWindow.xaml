<Window x:Class="VergiNoDogrula.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VergiNoDogrula.WPF"
        mc:Ignorable="d"
        Title="VergiNo ve TCKN Doğrula"
        Height="600" MinHeight="400" Width="800" MinWidth="600">
    <Grid Margin="8,8,8,8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="22" />
            <ColumnDefinition Width="22" />
            <ColumnDefinition Width="96" />
            <ColumnDefinition Width="22" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
            <Button Style="{StaticResource IconButtonStyle-28x24}"
                ToolTip="Yeni bir mükellef eklemek için tıklayın"
                Command="{Binding AddTaxPayerCommand}"
                CommandParameter="{Binding}"
                AutomationProperties.Name="Ekle">
                <Viewbox Width="14" Height="14">
                    <Path Fill="Black" Data="{StaticResource plus-circle}"/>
                </Viewbox>
            </Button>

            <Button Style="{StaticResource IconButtonStyle-28x24}"
                ToolTip="Seçili mükellefi kaydetmek için tıklayın"
                Command="{Binding SaveTaxPayerCommand}"
                CommandParameter="{Binding}"
                AutomationProperties.Name="Kaydet">
                <Viewbox Width="14" Height="14">
                    <Path Fill="#00008F" Data="{StaticResource floppy}"/>
                </Viewbox>
            </Button>

            <Button Style="{StaticResource IconButtonStyle-28x24}"
                ToolTip="Seçili mükellefi silmek için tıklayın"
                Command="{Binding DeleteTaxPayerCommand}"
                CommandParameter="{Binding}"
                AutomationProperties.Name="Sil">
                <Viewbox Width="14" Height="14">
                    <Path Fill="Black" Data="{StaticResource trash3}"/>
                </Viewbox>
            </Button>
        </StackPanel>

        <Border Grid.Column="0" Grid.ColumnSpan="5" Grid.Row="1" BorderBrush="#dbdbdb" BorderThickness="1" Margin="0,2,0,2" Padding="4">
            <TextBlock Text="{Binding Status}" FontSize="14" FontWeight="Bold" Margin="0" />
        </Border>

        <TextBox x:Name="SearchTextBox" Grid.Column="1" Grid.Row="0" Margin="4,4,0,0" VerticalAlignment="Top"
                 Text="{Binding SearchString, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock Text="Ara.." Grid.Column="1" Grid.Row="0" VerticalAlignment="Top" Margin="8,4,8,0"
                   Foreground="#989898" IsHitTestVisible="False">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFocused, ElementName=SearchTextBox}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <Button Grid.Column="2" Grid.Row="0" Style="{StaticResource IconButtonStyle-22x18}"
                ToolTip="Sorgu kutusunu temizle"
                Command="{Binding EmptySearchStringCommand}"
                CommandParameter="{Binding}"
                AutomationProperties.Name="SorguKutusuTemizle">
            <Viewbox Width="12" Height="12">
                <Path Fill="Black" Data="{StaticResource x-circle}"/>
            </Viewbox>
        </Button>
        
        <Label Grid.Column="0" Grid.Row="2" Content="Vergi Numarası:" VerticalAlignment="Top" Margin="0" />
        <TextBox Grid.Column="1" Grid.Row="2" Margin="4,4,0,0" VerticalAlignment="Top"
                 Style="{StaticResource DisabledWhenNullTextBoxStyle}"
                 Text="{Binding SelectedItem.TaxNumber, UpdateSourceTrigger=LostFocus, ValidatesOnNotifyDataErrors=True}" />

        <Button Grid.Column="2" Grid.Row="2" Style="{StaticResource IconButtonStyle-22x18}"
                ToolTip="Vergi numarasını kopyala"
                Command="{Binding CopyTaxNumberCommand}"
                CommandParameter="{Binding}"
                AutomationProperties.Name="VknKopyala">
            <Viewbox Width="12" Height="12">
                <Path Fill="Black" Data="{StaticResource copy}"/>
            </Viewbox>
        </Button>
        <Label Grid.Column="0" Grid.Row="4" Content="Ünvan:" VerticalAlignment="Top" Margin="0" />
        <TextBox Grid.Column="1" Grid.Row="4" Margin="4,4,0,0" VerticalAlignment="Top"
                 Style="{StaticResource DisabledWhenNullTextBoxStyle}"
                 Text="{Binding SelectedItem.Title, UpdateSourceTrigger=LostFocus, ValidatesOnNotifyDataErrors=True}">
        </TextBox>

        <DataGrid Grid.Column="0" Grid.ColumnSpan="5" Grid.Row="6" Grid.RowSpan="3" Margin="0"
                  ItemsSource="{Binding CollectionFiltered}" 
                  SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Vergi Numarası" Binding="{Binding TaxNumber}" Width="150" />
                <DataGridTextColumn Header="Ünvan" Binding="{Binding Title}" Width="*" />
            </DataGrid.Columns>
            <DataGrid.Style>
                <Style TargetType="DataGrid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding TaxPayers.Count}" Value="0">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGrid">
                                        <Border BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Background="{TemplateBinding Background}">
                                            <TextBlock Text="Henüz kayıt yok" 
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"
                                                       FontSize="14"
                                                       Foreground="Gray" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Style>
        </DataGrid>
    </Grid>
</Window>
