<Window x:Class="VergiNoDogrula.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VergiNoDogrula.WPF"
        xmlns:i18n="clr-namespace:VergiNoDogrula.i18n;assembly=VergiNoDogrula.i18n"
        mc:Ignorable="d"
        Title="{x:Static i18n:Strings.MainWindowTitle}"
        Height="400" MinHeight="400"
        Width="600" MinWidth="600" MaxWidth="600">
    <Grid Margin="8,8,8,8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="22" />
            <ColumnDefinition Width="22" />
            <ColumnDefinition Width="96" />
            <ColumnDefinition Width="22" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
            <Button Style="{StaticResource IconButtonStyle-28x24}"
                ToolTip="{x:Static i18n:Strings.AddTaxPayerTooltip}"
                Command="{Binding AddTaxPayerCommand}"
                CommandParameter="{Binding}"
                AutomationProperties.Name="Ekle">
                <Viewbox Width="14" Height="14">
                    <Path Fill="#0078D7" Data="{StaticResource plus-circle}"/>
                </Viewbox>
            </Button>

            <Button Style="{StaticResource IconButtonStyle-28x24}"
                ToolTip="{x:Static i18n:Strings.SaveTaxPayerTooltip}"
                Command="{Binding SaveTaxPayerCommand}"
                CommandParameter="{Binding}"
                AutomationProperties.Name="Kaydet">
                <Viewbox Width="14" Height="14">
                    <Path Fill="#0078D7" Data="{StaticResource floppy-fill}"/>
                </Viewbox>
            </Button>

            <Button Style="{StaticResource IconButtonStyle-28x24}"
                    ToolTip="{x:Static i18n:Strings.DeleteTaxPayerTooltip}"
                    Background="#C80000"
                    Command="{Binding DeleteTaxPayerCommand}"
                    CommandParameter="{Binding}"
                    AutomationProperties.Name="Sil">
                <Viewbox Width="14" Height="14">
                    <Path>
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Fill" Value="#F8F8F8"/>
                                <Setter Property="Data" Value="{StaticResource trash3}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Fill" Value="#C80000"/>
                                        <Setter Property="Data" Value="{StaticResource trash3}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Viewbox>
            </Button>
        </StackPanel>

        <StackPanel Grid.Row="0" Grid.Column="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource IconButtonStyle-28x24}"
                    ToolTip="{x:Static i18n:Strings.BackupDatabaseTooltip}"
                    Background="#1D9BF0"
                    Command="{Binding BackupDatabaseCommand}"
                    CommandParameter="{Binding}"
                    AutomationProperties.Name="Yedekle">
                <Viewbox Width="14" Height="14">
                    <Path>
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Data" Value="{StaticResource archive}"/>
                                <Setter Property="Fill" Value="#F8F8F8"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Fill" Value="#0078D7"/>
                                        <Setter Property="Data" Value="{StaticResource archive-fill}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Viewbox>
            </Button>

            <Button Style="{StaticResource IconButtonStyle-28x24}"
                    ToolTip="{x:Static i18n:Strings.ShowBackupListTooltip}"
                    Command="{Binding ShowBackupListCommand}"
                    CommandParameter="{Binding BackupService}"
                    AutomationProperties.Name="YedekListesi">
                <Viewbox Width="14" Height="14">
                    <Grid>
                        <Path Fill="#0078D7" Data="{StaticResource file-earmark-zip-fill}" Margin="4,4,0,0"/>
                        <Path Fill="#0078D7" Data="{StaticResource file-earmark}" Margin="0"/>
                        <Path Fill="#0078D7" Data="{StaticResource file-earmark}" Margin="-4,-4,0,0"/>
                    </Grid>
                </Viewbox>
            </Button>

            <Button Style="{StaticResource IconButtonStyle-28x24}"
                    ToolTip="{x:Static i18n:Strings.AboutTooltip}"
                    Command="{Binding ShowAboutCommand}"
                    AutomationProperties.Name="Hakkında">
                <Viewbox Width="14" Height="14">
                    <Path Fill="#1D9BF0" Data="{StaticResource info-circle-fill}"/>
                </Viewbox>
            </Button>
        </StackPanel>

        <Border Grid.Column="0" Grid.ColumnSpan="7" Grid.Row="1" BorderBrush="#dbdbdb" BorderThickness="1" Margin="0,2,0,2" Padding="4">
            <TextBlock Text="{Binding Status}" FontSize="14" FontWeight="Bold" Margin="0" />
        </Border>

        <TextBox x:Name="SearchTextBox" Grid.Column="1" Grid.Row="0" Margin="4,4,0,0" VerticalAlignment="Top"
                 Text="{Binding SearchString, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock Text="{x:Static i18n:Strings.SearchPlaceholder}" Grid.Column="1" Grid.Row="0" VerticalAlignment="Top" Margin="8,4,8,0"
                   Foreground="#989898" IsHitTestVisible="False">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsFocused, ElementName=SearchTextBox}" Value="False" />
                                <Condition Binding="{Binding Text.Length, ElementName=SearchTextBox, FallbackValue=0}" Value="0" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <Button Grid.Column="2" Grid.Row="0" Style="{StaticResource IconButtonStyle-22x18}"
                ToolTip="{x:Static i18n:Strings.ClearSearchTooltip}"
                Command="{Binding EmptySearchStringCommand}"
                CommandParameter="{Binding}"
                AutomationProperties.Name="SorguKutusuTemizle">
            <Viewbox Width="12" Height="12">
                <Path Fill="Black" Data="{StaticResource x-circle}"/>
            </Viewbox>
        </Button>
        
        <Label Grid.Column="0" Grid.Row="2" Content="{x:Static i18n:Strings.TaxNumberLabel}" VerticalAlignment="Top" Margin="0" />
        <TextBox Grid.Column="1" Grid.Row="2" Margin="4,4,0,0" VerticalAlignment="Top"
                 Style="{StaticResource DisabledWhenNullTextBoxStyle}"
                 Text="{Binding SelectedItem.TaxNumber, UpdateSourceTrigger=LostFocus, ValidatesOnNotifyDataErrors=True}" />

        <Button Grid.Column="2" Grid.Row="2" Style="{StaticResource IconButtonStyle-22x18}"
                ToolTip="{x:Static i18n:Strings.CopyTaxNumberTooltip}"
                Command="{Binding CopyTaxNumberCommand}"
                CommandParameter="{Binding}"
                AutomationProperties.Name="VknKopyala">
            <Viewbox Width="12" Height="12">
                <Path Fill="Black" Data="{StaticResource copy}"/>
            </Viewbox>
        </Button>
        <Label Grid.Column="0" Grid.Row="4" Content="{x:Static i18n:Strings.TitleLabel}" VerticalAlignment="Top" Margin="0" />
        <TextBox Grid.Column="1" Grid.ColumnSpan="7" Grid.Row="4" Margin="4,4,0,0" VerticalAlignment="Top"
                 Style="{StaticResource DisabledWhenNullTextBoxStyle}"
                 Text="{Binding SelectedItem.Title, UpdateSourceTrigger=LostFocus, ValidatesOnNotifyDataErrors=True}">
        </TextBox>

        <DataGrid Grid.Column="0" Grid.ColumnSpan="7" Grid.Row="6" Grid.RowSpan="3" Margin="0"
                  ItemsSource="{Binding CollectionFiltered}" 
                  SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static i18n:Strings.TaxNumberHeader}" Binding="{Binding TaxNumber}" Width="150" />
                <DataGridTextColumn Header="{x:Static i18n:Strings.TitleHeader}" Binding="{Binding Title}" Width="*" />
            </DataGrid.Columns>
            <DataGrid.Style>
                <Style TargetType="DataGrid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding TaxPayers.Count}" Value="0">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGrid">
                                        <Border BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Background="{TemplateBinding Background}">
                                            <TextBlock Text="{x:Static i18n:Strings.NoRecordsYet}" 
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"
                                                       FontSize="14"
                                                       Foreground="Gray" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Style>
        </DataGrid>
    </Grid>
</Window>
