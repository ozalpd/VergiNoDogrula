<Window x:Class="VergiNoDogrula.WPF.Dialogs.BackupListDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:VergiNoDogrula.WPF.Dialogs"
        xmlns:i18n="clr-namespace:VergiNoDogrula.i18n;assembly=VergiNoDogrula.i18n"
        x:ClassModifier="internal"
        Title="{x:Static i18n:Strings.BackupListDialogTitle}" Height="320" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Border x:Name="StatusContainer" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0" BorderBrush="#dbdbdb" BorderThickness="1" Margin="0,0,0,4" Padding="4">
            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                <TextBlock x:Name="StatusTextBlock" FontSize="13" FontWeight="Bold" Margin="0,0,0,4" />
                <TextBlock x:Name="StatusTextBlock2" FontSize="13" FontWeight="Bold" />
            </StackPanel>
        </Border>

        <DataGrid Name="BackupFilesDataGrid" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F5F5F5"
                  Margin="0,0,0,16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static i18n:Strings.FileNameHeader}" Binding="{Binding FileName}" Width="*" MinWidth="200"/>
                <DataGridTextColumn Header="{x:Static i18n:Strings.CreatedDateHeader}" Binding="{Binding CreatedDate, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" Width="150"/>
                <DataGridTextColumn Header="{x:Static i18n:Strings.SizeHeader}" Binding="{Binding FormattedSize}" Width="100"/>
            </DataGrid.Columns>
            <DataGrid.Style>
                <Style TargetType="DataGrid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Items.Count, RelativeSource={RelativeSource Self}}" Value="0">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate>
                                        <TextBlock Text="{x:Static i18n:Strings.NoBackupFilesFound}" 
                                                   HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"
                                                   FontSize="14"
                                                   Foreground="Gray"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.Style>
        </DataGrid>

        <StackPanel Grid.Column="0" Grid.Row="2" Orientation="Horizontal">
            <Button x:Name="OpenBackupFolderButton" Style="{StaticResource IconButtonStyle-28x24}"
                    ToolTip="{x:Static i18n:Strings.OpenBackupFolderTooltip}"
                    AutomationProperties.Name="OpenBackupFolder"
                    Click="OpenBackupFolderButton_Click">
                <Viewbox Width="16" Height="16">
                    <Path Fill="#0078D7" Data="{StaticResource folder-symlink-fill}"/>
                </Viewbox>
            </Button>
            <Button x:Name="OpenDatabaseFolderButton" Style="{StaticResource IconButtonStyle-28x24}"
                    ToolTip="{x:Static i18n:Strings.OpenDatabaseFolderTooltip}"
                    AutomationProperties.Name="OpenDatabaseFolder"
                    Click="OpenDatabaseFolderButton_Click">
                <Viewbox Width="16" Height="16">
                    <Path Fill="#0078D7" Data="{StaticResource database}"/>
                </Viewbox>
            </Button>
        </StackPanel>
        <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{x:Static i18n:Strings.CloseButton}" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
