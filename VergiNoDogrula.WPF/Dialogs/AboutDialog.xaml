<Window x:Class="VergiNoDogrula.WPF.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hakkında" 
        Height="320" 
        Width="450" 
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Application Icon -->
        <Image Grid.Row="0" 
               Width="64" 
               Height="64" 
               HorizontalAlignment="Center" 
               Margin="0,0,0,10"
               Source="/Assets/tax-icon-01.ico"/>

        <!-- Product Name -->
        <TextBlock Grid.Row="1" 
                   Text="{Binding Product}" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,5"/>

        <!-- Version -->
        <TextBlock Grid.Row="2" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,5">
            <Run Text="Sürüm:" FontWeight="SemiBold"/>
            <Run Text="{Binding Version, Mode=OneWay}"/>
        </TextBlock>

        <!-- Description -->
        <TextBlock Grid.Row="3" 
                   Text="{Binding Description}" 
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="0,0,0,5"/>

        <!-- Copyright -->
        <TextBlock Grid.Row="5" 
                   Text="{Binding Copyright}" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <!-- GitHub Link -->
        <TextBlock Grid.Row="6" 
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top">
            <Hyperlink NavigateUri="https://github.com/ozalpd/VergiNoDogrula" 
                       RequestNavigate="Hyperlink_RequestNavigate">
                <Run Text="GitHub'da Görüntüle"/>
            </Hyperlink>
        </TextBlock>

        <!-- OK Button -->
        <Button Grid.Row="7" 
                Content="Tamam" 
                Width="80" 
                Height="28"
                IsDefault="True"
                Click="OkButton_Click"
                HorizontalAlignment="Center"/>
    </Grid>
</Window>
